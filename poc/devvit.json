{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "strata-poc",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "entry": "index.html",
        "height": "regular",
        "inline": true
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "permissions": {
    "http": {
      "enable": true,
      "domains": ["api.openai.com"]
    },
    "redis": true,
    "reddit": {
      "enable": true,
      "scope": "moderator"
    }
  },
  "settings": {
    "global": {
      "openaiApiKey": {
        "type": "string",
        "label": "OpenAI API Key",
        "isSecret": true
      }
    }
  },
  "menu": {
    "items": [
      {
        "label": "Strata: Inspect Comment",
        "description": "Read comment fields and log them",
        "location": "comment",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/inspect-comment"
      },
      {
        "label": "Strata: Find Similar",
        "description": "Find semantically similar comments",
        "location": "comment",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/find-similar"
      },
      {
        "label": "Strata: Seed Test Data",
        "description": "Post test comments across different topics for similarity testing",
        "location": "post",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/seed-test-data"
      },
      {
        "label": "Strata: Create Dashboard",
        "description": "Create a Strata dashboard post",
        "location": "post",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/create-dashboard"
      },
      {
        "label": "Strata: Probe Backfill",
        "description": "Test backfill APIs (getNewPosts, getComments, getModerationLog)",
        "location": "post",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/probe-backfill"
      },
      {
        "label": "Strata: Probe Redis Size",
        "description": "Measure actual storage per embedding",
        "location": "post",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/probe-redis-size"
      },
      {
        "label": "Strata: Fetch Rules",
        "description": "Read subreddit rules via API",
        "location": "post",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/fetch-rules"
      },
      {
        "label": "Strata: Test Modmail",
        "description": "Send a test modmail notification",
        "location": "post",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/test-modmail"
      },
      {
        "label": "Strata: Seed 256d",
        "description": "Generate 256-dim embeddings for comparison",
        "location": "post",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/seed-256d"
      },
      {
        "label": "Strata: Remove with Reason",
        "description": "Remove comment and attach a removal reason",
        "location": "comment",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/remove-with-reason"
      },
      {
        "label": "Strata: Precedent Panel",
        "description": "View similar precedents and take action",
        "location": "comment",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/precedent-panel"
      },
      {
        "label": "Strata: Bulk Remove Test",
        "description": "Test bulk removal timing within 30s",
        "location": "post",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/bulk-remove-test"
      },
      {
        "label": "Strata: LLM Panel",
        "description": "Precedent panel with LLM recommendation",
        "location": "comment",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/llm-panel"
      }
    ]
  },
  "forms": {
    "similarResults": "/internal/forms/similar-results",
    "probeResults": "/internal/forms/probe-results",
    "comparisonResults": "/internal/forms/comparison-results",
    "removeWithReason": "/internal/forms/remove-with-reason",
    "precedentPanel": "/internal/forms/precedent-panel",
    "bulkRemoveTest": "/internal/forms/bulk-remove-test",
    "llmPanel": "/internal/forms/llm-panel"
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install",
    "onCommentSubmit": "/internal/triggers/comment-submit",
    "onModAction": "/internal/triggers/mod-action",
    "onCommentReport": "/internal/triggers/comment-report"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "dev": {
    "subreddit": "strata_poc_dev"
  }
}
