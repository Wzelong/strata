{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "strata-hackathon",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "entry": "index.html",
        "height": "tall"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "permissions": {
    "http": {
      "enable": true,
      "domains": [
        "api.openai.com"
      ]
    },
    "redis": true,
    "reddit": {
      "enable": true,
      "scope": "moderator"
    }
  },
  "settings": {
    "global": {
      "strataEncryptionKey": {
        "type": "string",
        "label": "Encryption key for per-subreddit OpenAI keys",
        "isSecret": true
      }
    }
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/app-install",
    "onPostSubmit": "/internal/triggers/post-submit",
    "onCommentSubmit": "/internal/triggers/comment-submit",
    "onPostDelete": "/internal/triggers/post-delete",
    "onCommentDelete": "/internal/triggers/comment-delete"
  },
  "scheduler": {
    "tasks": {
      "ingest-batch": { "endpoint": "/internal/scheduler/ingest-batch" },
      "scan": { "endpoint": "/internal/scheduler/scan" },
      "recluster": { "endpoint": "/internal/scheduler/recluster" }
    }
  },
  "menu": {
    "items": [
      {
        "label": "Strata: Dashboard",
        "description": "Create the Strata dashboard post",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/dashboard"
      },
      {
        "label": "Strata: Reset Data",
        "description": "Wipe all Strata data from Redis, including the OpenAI API key",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/reset"
      },
      {
        "label": "Strata: Surface",
        "description": "Find buried connections to this item",
        "location": [
          "post",
          "comment"
        ],
        "forUserType": "moderator",
        "endpoint": "/internal/menu/surface"
      },
      {
        "label": "Strata: Similar prior decisions",
        "description": "Check this item against previously removed items",
        "location": [
          "post",
          "comment"
        ],
        "forUserType": "moderator",
        "endpoint": "/internal/menu/similar-decisions"
      }
    ]
  },
  "forms": {
    "surfaceResults": "/internal/forms/surface-results",
    "seedResults": "/internal/forms/seed-results",
    "similarDecisionsResults": "/internal/forms/similar-decisions-results"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "dev": {
    "subreddit": "strata_hackathon_dev"
  }
}