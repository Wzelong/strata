{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "strata-hackathon",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "entry": "index.html",
        "height": "regular"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "permissions": {
    "http": {
      "enable": true,
      "domains": [
        "api.openai.com",
        "raw.githubusercontent.com"
      ]
    },
    "redis": true,
    "reddit": {
      "enable": true,
      "scope": "moderator"
    }
  },
  "settings": {
    "global": {
      "openaiApiKey": {
        "type": "string",
        "label": "OpenAI API Key",
        "isSecret": true
      }
    }
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/app-install",
    "onPostSubmit": "/internal/triggers/post-submit",
    "onCommentSubmit": "/internal/triggers/comment-submit"
  },
  "scheduler": {
    "tasks": {
      "ingest-batch": { "endpoint": "/internal/scheduler/ingest-batch" },
      "scan": { "endpoint": "/internal/scheduler/scan" }
    }
  },
  "menu": {
    "items": [
      {
        "label": "Strata: Seed Data",
        "description": "Load demo dataset into Redis",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/seed-data"
      },
      {
        "label": "Strata: Surface",
        "description": "Find buried connections to this item",
        "location": [
          "post",
          "comment"
        ],
        "forUserType": "moderator",
        "endpoint": "/internal/menu/surface"
      },
      {
        "label": "Strata: Ingest",
        "description": "Import subreddit posts and comments into Strata",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/ingest"
      },
      {
        "label": "Strata: Scan",
        "description": "Scan stored items for buried connections",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/scan"
      }
    ]
  },
  "forms": {
    "surfaceResults": "/internal/forms/surface-results",
    "seedResults": "/internal/forms/seed-results",
    "ingestDates": "/internal/forms/ingest-dates",
    "ingestConfirm": "/internal/forms/ingest-confirm"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "dev": {
    "subreddit": "strata_hackathon_dev"
  }
}